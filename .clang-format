# Generated by CLion for Google
BasedOnStyle: Google

# Custom include ordering: All maxcompute_odbc headers before system headers
# This ensures platform.h is included before ODBC headers
SortIncludes: true
IncludeBlocks: Merge
IncludeCategories:
  # All maxcompute_odbc headers first (Priority 0 = highest)
  - Regex:           '"maxcompute_odbc/'
    Priority:        0
  # All other system headers (Priority 1)
  - Regex:           '<'
    Priority:        1